pipeline {
    agent any

    stages {
        stage('Cloneing REPO') {
            steps {
               git branch: 'main', changelog: false, poll: false, url: 'https://github.com/gyallareddy/jenkins-tutorial.git'
            }
        }
        stage('BUILD') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'mvn clean package'
                }
            }
        }
        stage('TEST') {
             steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'mvn test'
                }
            }
        }
        stage('COMPILE') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'mvn compile'
                    sh 'java -jar target/java-jenkins-docker-1.0-SNAPSHOT.jar'
                }
            }
        }
        stage('Dcker Image Creation') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'docker build -t java-jenkins-docker:latest .'
                }
            }
        }
        stage('Docker Image Tag') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'docker run --rm java-jenkins-docker:latest'
                }
            }
        }
        stage('Docker Login') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'docker login -u yallareddyg -p g123690R@'
                }
            }
        }
        stage('Docker push') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    sh 'docker push yallareddyg/app:v1'
                }
            }
        }
        stage('Cleaning Workspace') {
            steps {
                dir('3-java-jenkins-docker-app') {
                    cleanWs()
                }
            }
        }
    }
}
